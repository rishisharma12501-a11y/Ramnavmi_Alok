<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jai Shree Ram - Ram Naam Varsha</title>
    <link href="https://fonts.googleapis.com/css2?family=Mukta:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #FFD700;
            --deep-red: #8B0000;
        }

      body, html {
            margin: 0; padding: 0;
            width: 100%; min-height: 100%;
            background: linear-gradient(to bottom, #FF4500, #8B0000, #FF4500, #8B0000);
            font-family: 'Mukta', sans-serif;
            color: white; overflow-x: hidden;
        }
        /* --- ENTRY PAGE --- */
        #entry-page {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle, var(--gold), #FF4500);
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            z-index: 1000; transition: 1s ease-in-out;
            text-align: center;
        }

        .gift-box { width: 150px; cursor: pointer; animation: bounce 1s infinite alternate; filter: drop-shadow(0 0 20px #fff); }
        @keyframes bounce { from { transform: scale(1); } to { transform: scale(1.15); } }

        /* --- CONTENT WRAPPER --- */
        #main-content { display: none; opacity: 0; transition: 1.5s; position: relative; z-index: 5; }
        .page-wrapper { width: 100%; display: flex; flex-direction: column; align-items: center; padding: 20px 0 100px 0; }
        .section { width: 90%; max-width: 550px; margin: 15px 0; }
        
        .card-3d {
            background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(12px);
            border: 4px double var(--gold); border-radius: 20px; padding: 25px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4); text-align: center;
        }

        .ram-img-circle { width: 270px; height: 270px; border-radius: 50%; border: 6px solid var(--gold); box-shadow: 0 0 40px var(--gold); object-fit: cover; margin-bottom: 20px; }
        .alok-img-circle { width: 220px; height: 220px; border-radius: 50%; border: 6px solid var(--gold); box-shadow: 0 0 40px var(--gold); object-fit: cover; margin-bottom: 20px; }
        
        h1 { font-size: 2.5em; color: var(--gold); text-shadow: 3px 3px 5px #000; margin: 10px 0; }
        .shlok { color: var(--gold); font-size: 1.6em; font-weight: bold; margin: 10px 0; }
        .shayari { font-size: 1.25em; line-height: 1.6; font-weight: bold; }

        /* Countdown Style */
        #countdown { display: flex; justify-content: center; gap: 15px; font-weight: bold; color: var(--gold); font-size: 1.2em; margin-top: 10px; }
        #countdown div { background: rgba(0, 0, 0, 0.4); padding: 10px; border-radius: 10px; min-width: 60px; border: 1px solid var(--gold); }

        .music-ctrl { position: fixed; top: 20px; right: 20px; z-index: 100; background: var(--gold); border: none; border-radius: 50%; width: 50px; height: 50px; cursor: pointer; font-size: 20px; }
        .share-btn { background: #25D366; color: white; padding: 15px 40px; border-radius: 50px; text-decoration: none; font-weight: bold; display: inline-block; margin-top: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
        #ram-canvas { position: fixed; top: 0; left: 0; pointer-events: none; z-index: 2; }
    </style>
</head>
<body>

    <div id="entry-page" onclick="revealMagic()">
        <img src="https://cdn-icons-png.flaticon.com/512/1139/1139982.png" class="gift-box">
        <h2 style="color: #8B0000; text-align: center;">🚩 राम नवमी का विशेष उपहार 🚩<br><small>(खोलने के लिए क्लिक करें)</small></h2>
    </div>

    <canvas id="ram-canvas"></canvas>

    <div id="main-content">
        <button class="music-ctrl" onclick="toggleMusic()">🎵</button>
        <audio id="bg-music" loop>
            <source src="https://raw.githubusercontent.com/rishisharma12501-a11y/Ram-navami-wishing-site-/main/Jai%20Shree%20Ram%20Ringtone%20Download%20Mp3%20Dj%20Instrumental%20-%20MobCup.Com.Co.mp3" type="audio/mpeg">
        </audio>

        <div class="page-wrapper">
            <div class="section">
                <div class="card-3d">
                    <img src="https://t4.ftcdn.net/jpg/05/67/25/19/360_F_567251954_fv1O7TqBJYK5I5yIYcBjfGsukK04IGR9.jpg" class="ram-img-circle">  
                    
                    <div class="section">
                        <img src="C:\Users\Hi\OneDrive\Desktop\Ramnavmi site alok\WhatsApp Image 2026-03-19 at 7.29.24 PM.jpeg" class="alok-img-circle">
                        <div id="displayName" style="font-size: 2.5em; color: gold; font-weight: bold; text-shadow: 2px 2px 10px #000; min-height: 1.2em;"></div>
                    </div>

                    <p style="font-size: 1.2em; color: white; margin: 0;"><h2>आलोक कुमार (युवा नेता)</h2>की तरफ से आपको सपरिवार</p>
                    <h1>राम नवमी की हार्दिक शुभकामनाएं</h1>
                </div>
            </div>

            <div class="section">
                <div class="card-3d">
                    <p class="shlok">॥ राम नवमी आगमन ॥</p>
                    <div id="countdown">
                        <div><span id="days">00</span><br><small>दिन</small></div>
                        <div><span id="hours">00</span><br><small>घंटे</small></div>
                        <div><span id="minutes">00</span><br><small>मिनट</small></div>
                        <div><span id="seconds">00</span><br><small>सेकंड</small></div>
                    </div>
                </div>
            </div>

            <div class="section">
                <div class="card-3d">
                    <p class="shlok">॥ मंगल भवन अमंगल हारी ॥</p>
                    <p class="shayari">"राम जिनका नाम है, अयोध्या जिनका धाम है,<br>ऐसे रघुनंदन को, हमारा कोटि-कोटि प्रणाम है।"</p>
                    <p class="shayari">
                        "नवमी तिथि मधुमास पुनीता, शुक्ल पक्ष अभिजित प्रीता।<br>
                        मध्य दिवस अति शीत न घामा, पावन काल लोक विश्रामा॥"
                    </p>
                </div>
            </div>

            <div class="section">
                <div class="card-3d">
                    <p class="shayari">"जिनके मन में श्री राम हैं,<br>भाग्य में उनके वैकुण्ठ धाम है,<br>उनके चरणों में जिसने जीवन वार दिया,<br>संसार में उसका कल्याण है।"</p>
                </div>
            </div>

            <div class="section">
                <div class="card-3d">
                    <p class="shayari">"राम जी की ज्योति से नूर मिलता है,<br>सबके दिलों को सुरूर मिलता है,<br>जो भी जाता है राम के द्वार,<br>उसे कुछ न कुछ ज़रूर मिलता है।"</p>
                    <a href="javascript:void(0)" class="share-btn" onclick="shareWhatsapp()">🚩 सबको भेजे </a>
                </div>
            </div>
            
            <div style="margin-top: 50px; font-size: 40px;">🏹🚩🏹</div>
        </div>
    </div>

    <script>
        let userName = ""; // Global variable for name

        function revealMagic() {
            document.getElementById('bg-music').play().catch(e => console.log("Music click needed"));
            document.getElementById('entry-page').style.transform = 'translateY(-100%)';
            setTimeout(() => {
                document.getElementById('entry-page').style.display = 'none';
                document.getElementById('main-content').style.display = 'block';
                setTimeout(() => { document.getElementById('main-content').style.opacity = '1'; }, 50);
            }, 800);
        }

        function toggleMusic() {
            var audio = document.getElementById("bg-music");
            audio.paused ? audio.play() : audio.pause();
        }

        function shareWhatsapp() {
            let name = userName || "शुभकामनाएं";
            let shareUrl = window.location.origin + window.location.pathname + "?name=" + encodeURIComponent(name);
            const text = "*" + name + "* 🚩 ने आपके लिए एक बहुत ही सुंदर राम नवमी गिफ्ट भेजा है। यहाँ देखें:\n\n" + shareUrl;
            window.open("https://api.whatsapp.com/send?text=" + encodeURIComponent(text), '_blank');
        }

        // --- Rain Animation ---
        const canvas = document.getElementById('ram-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        const words = ["राम", "श्री राम", "जय श्री राम"];
        const particles = [];
        for(let i=0; i<50; i++) {
            particles.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                text: words[Math.floor(Math.random()*words.length)],
                speed: Math.random() * 2 + 1
            });
        }
        function animate() {
            ctx.clearRect(0,0,canvas.width, canvas.height);
            ctx.fillStyle = "rgba(255, 215, 0, 0.6)"; ctx.font = "20px Mukta";
            particles.forEach(p => {
                ctx.fillText(p.text, p.x, p.y);
                p.y += p.speed;
                if(p.y > canvas.height) p.y = -20;
            });
            requestAnimationFrame(animate);
        }
        animate();

        // --- Countdown Logic ---
        function startTimer() {
            const ramNavmiDate = new Date("March 26, 2026 00:00:00").getTime();
            setInterval(function() {
                const now = new Date().getTime();
                const d = ramNavmiDate - now;
                if (d > 0) {
                    document.getElementById("days").innerHTML = Math.floor(d / (1000 * 60 * 60 * 24));
                    document.getElementById("hours").innerHTML = Math.floor((d % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    document.getElementById("minutes").innerHTML = Math.floor((d % (1000 * 60 * 60)) / (1000 * 60));
                    document.getElementById("seconds").innerHTML = Math.floor((d % (1000 * 60)) / 1000);
                }
            }, 1000);
        }
        startTimer();

        // Handle URL Name (Isse link wala naam show hoga bina input box ke)
        let params = new URLSearchParams(window.location.search);
        if(params.get('name')) {
            userName = params.get('name');
            let displayElem = document.getElementById('displayName');
            if(displayElem) {
                displayElem.innerText = "🚩 " + userName + " 🚩";
            }
        }
    </script>
</body>
</html>
